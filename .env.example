# Copy to .env, fill in, then `set -a && source .env && set +a` before running.

# Firebase web API key for the project the DartStream backend trusts
# (Project: dartstream-prod, Sample-App-Brian-Chebon web app). Get it from the
# Firebase console > Project settings > your web app. This file is the public
# template — put the real value only in your local .env (gitignored).
FIREBASE_API_KEY=your-firebase-web-api-key

# Test user for the smoke CLI. On first run the user won't exist, so the CLI
# auto-signs them up — any valid email + strong password works. Fill these in
# your local .env (which is gitignored); do NOT commit real credentials here.
TEST_EMAIL=you@example.com
TEST_PASSWORD=change-me

# Per-service base URLs. Defaults match dev-api.dartstream.io subdomain pattern.
API_AUTH=https://dev-apiauth.dartstream.io
API_PLATFORM=https://dev-apiplatform.dartstream.io
API_EXPERIENCE=https://dev-apiexperience.dartstream.io
API_REACTIVE=https://dev-apireactive.dartstream.io
API_PERSISTENCE=https://dev-apipersistence.dartstream.io

# OAuth2 client_credentials (machine-to-machine) — used by bin/oauth2_deepdive.dart.
# Create an Application in the dashboard (Settings -> Applications -> Create
# OAuth2 Client), copy the clientId + clientSecret ONCE. The secret is confidential:
# put it only in your local .env (gitignored), never in a browser/Flutter bundle.
# Leave the optional expiry/Date BLANK unless you set a clearly future timestamp —
# a same-day date can mint an already-expired client.
API_BILLING=https://dev-apibilling.dartstream.io
OAUTH2_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OAUTH2_CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: space-separated subset of the client's scopes (default = all granted).
# OAUTH2_SCOPE=platform:read flags:read projects:read
